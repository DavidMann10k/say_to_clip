# Copy to ~/.config/say_to_clip/env and edit.
# Do not commit real API keys.

# local keeps everything on this machine.
# groq uses Groq for both transcription and transcript cleanup.
DICTATE_PROVIDER=local

# You can split providers if you want hybrid mode:
# DICTATE_TRANSCRIBE_PROVIDER=groq
# DICTATE_CLEAN_PROVIDER=local

# Local transcription defaults:
DICTATE_MIC_SOURCE=@DEFAULT_SOURCE@
SAY_TO_CLIP_MIN_MEAN_VOLUME_DB=-50
DICTATE_WHISPER_MODEL=base.en
DICTATE_WHISPER_LANGUAGE=en

# Local Ollama cleanup defaults:
DICTATE_OLLAMA_URL=http://127.0.0.1:11434
DICTATE_OLLAMA_MODEL=gemma3:12b
DICTATE_OLLAMA_KEEP_ALIVE=30m

# Logging is off by default. Enable operational logs without transcript text:
# SAY_TO_CLIP_LOG=1
#
# Enable transcript/API payload logging only when debugging sensitive issues:
# SAY_TO_CLIP_LOG_CONTENT=1

# Groq defaults:
DICTATE_GROQ_BASE_URL=https://api.groq.com/openai/v1
DICTATE_GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
DICTATE_GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Required when using Groq:
# GROQ_API_KEY=gsk_...
