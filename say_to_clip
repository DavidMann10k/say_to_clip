show_recording_notification() {
  command -v notify-send >/dev/null 2>&1 || return 0
  ensure_notification_icons

  local body="${1:-Mic monitor starting...}"
  local formatted_body
  formatted_body="$(recording_notification_body "$body")"
  local id
  id="$(notify-send -a say_to_clip -u critical -t 0 -p -i "$RECORDING_ICON_FILE" "Recording" "$formatted_body" 2>/dev/null || true)"
  id="${id%%$'\n'*}"
  case "$id" in
    ''|*[!0-9]*)
      notify-send -a say_to_clip -u critical -t 0 -i "$RECORDING_ICON_FILE" "Recording" "$formatted_body" >/dev/null 2>&1 || true
      return 0
      ;;
  esac

  rm -f "$LEGACY_RECORDING_NOTIFICATION_ID_FILE"
  printf '%s\n' "$id" >"$RECORDING_NOTIFICATION_ID_FILE"
  log "notification: recording_id=${id}"
}

recording_notification_id() {
  sed -n '1p' "$RECORDING_NOTIFICATION_ID_FILE" 2>/dev/null || true
}

update_recording_notification() {
  command -v notify-send >/dev/null 2>&1 || return 0

  local body="$1"
  local id="${2:-}"
  local formatted_body
  if [ -z "$id" ]; then
    id="$(recording_notification_id)"
  fi
  case "$id" in
    ''|*[!0-9]*) return 0 ;;
  esac

  ensure_notification_icons
  formatted_body="$(recording_notification_body "$body")"
  notify-send -a say_to_clip -r "$id" -u critical -t 0 -i "$RECORDING_ICON_FILE" "Recording" "$formatted_body" >/dev/null 2>&1 || true
}

dismiss_notification_id() {
  local id="$1"

  case "$id" in
    ''|*[!0-9]*) return 0 ;;
  esac

  if command -v makoctl >/dev/null 2>&1 && makoctl dismiss -n "$id" -h >/dev/null 2>&1; then
    log "notification: dismissed recording_id=${id}"
    return 0
  fi

  if command -v notify-send >/dev/null 2>&1; then
    notify-send -a say_to_clip -r "$id" -t 1 "Recording stopped" >/dev/null 2>&1 || true
  fi
}

dismiss_recording_notification() {
  local id
  local legacy_id
  id="$(recording_notification_id)"
  legacy_id="$(sed -n '1p' "$LEGACY_RECORDING_NOTIFICATION_ID_FILE" 2>/dev/null || true)"
  rm -f "$RECORDING_NOTIFICATION_ID_FILE"
  rm -f "$LEGACY_RECORDING_NOTIFICATION_ID_FILE"
  dismiss_notification_id "$id"
  dismiss_notification_id "$legacy_id"
}

notify_ready() {
  command -v notify-send >/dev/null 2>&1 || return 0
  ensure_notification_icons
  notify-send -a say_to_clip -t 5000 -i "$READY_ICON_FILE" "Ready" "Copied transcript" >/dev/null 2>&1 || true
}

recording_notification_body() {
  local body="$1"

  printf '<span font_family="monospace">%s</span>' "$body"
}

mic_level_monitor_enabled() {
  truthy "$LIVE_LEVEL_ENABLED"
}

mic_level_monitor_pid() {
  if [ -f "$MIC_LEVEL_MONITOR_PID_FILE" ]; then
    cat "$MIC_LEVEL_MONITOR_PID_FILE"
  elif [ -f "$LEGACY_MIC_LEVEL_MONITOR_PID_FILE" ]; then
    cat "$LEGACY_MIC_LEVEL_MONITOR_PID_FILE"
  fi
}

is_mic_level_monitor_running() {
  local pid
  pid="$(mic_level_monitor_pid || true)"
  [ -n "${pid:-}" ] && kill -0 "$pid" >/dev/null 2>&1
}

mic_source_is_muted() {
  local output

  if command -v pactl >/dev/null 2>&1; then
    output="$(pactl get-source-mute "$MIC_SOURCE" 2>/dev/null || true)"
    case "$output" in
      *yes*) return 0 ;;
    esac

    if [ "$MIC_SOURCE" = "@DEFAULT_SOURCE@" ]; then
      output="$(pactl get-source-mute @DEFAULT_SOURCE@ 2>/dev/null || true)"
      case "$output" in
        *yes*) return 0 ;;
      esac
    fi
  fi

  if command -v wpctl >/dev/null 2>&1; then
    if [ "$MIC_SOURCE" = "@DEFAULT_SOURCE@" ]; then
      output="$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ 2>/dev/null || true)"
    else
      output="$(wpctl get-volume "$MIC_SOURCE" 2>/dev/null || true)"
    fi
    case "$output" in
      *MUTED*) return 0 ;;
    esac
  fi

  return 1
}

level_bar() {
  local level="$1"
  local width=10
  local filled

  case "$level" in
    ''|nan|inf|-inf) filled=0 ;;
    *)
      filled="$(awk -v level="$level" -v min="$NO_SIGNAL_DB" -v max=-20 -v width="$width" '
        BEGIN {
          if (level < min) level = min
          if (level > max) level = max
          printf "%d", ((level - min) / (max - min)) * width
        }
      ' 2>/dev/null || printf '0')"
      ;;
  esac

  local i
  for ((i = 0; i < width; i += 1)); do
    if [ "$i" -lt "$filled" ]; then
      printf '█'
    else
      printf '░'
    fi
  done
}

format_db() {
  local level="$1"

  case "$level" in
    ''|nan|inf|-inf) printf -- '-inf' ;;
    *) awk -v level="$level" 'BEGIN { printf "%.0f", level }' 2>/dev/null || printf -- '-inf' ;;
  esac
}

mic_level_notification_body() {
  local level="$1"
  local status db bar color

  if mic_source_is_muted; then
    printf '<span foreground="#ef4444">░░░░░░░░░░</span> Mic muted'
    return 0
  fi

  case "$level" in
    ''|nan|inf|-inf)
      status="Mic muted"
      ;;
    *)
      if awk -v level="$level" -v floor="$NO_SIGNAL_DB" 'BEGIN { exit !(level <= floor) }'; then
        status="Mic muted"
      elif awk -v level="$level" -v quiet="$MIN_MEAN_VOLUME_DB" 'BEGIN { exit !(level < quiet) }'; then
        status="Mic quiet"
      else
        status="Mic live"
      fi
      ;;
  esac

  db="$(format_db "$level")"
  bar="$(level_bar "$level")"
  case "$status" in
    "Mic live") color="#22c55e" ;;
    *) color="#ef4444" ;;
  esac
  printf '<span foreground="%s">%s</span> %s  %s dBFS' "$color" "$bar" "$status" "$db"
}

mic_level_sample_count() {
  awk -v seconds="$LEVEL_SAMPLE_SECONDS" 'BEGIN {
    count = int(16000 * seconds)
    if (count < 1600) count = 1600
    printf "%d", count
  }'
}

record_mic_level_sample() {
  local sample_count="$1"
  shift

  if command -v timeout >/dev/null 2>&1; then
    timeout 3 pw-record "$@" \
      --channels 1 \
      --rate 16000 \
      --format s16 \
      --raw \
      --sample-count "$sample_count" \
      -
  else
    pw-record "$@" \
      --channels 1 \
      --rate 16000 \
      --format s16 \
      --raw \
      --sample-count "$sample_count" \
      -
  fi
}

capture_mic_level() {
  local sample_count="$1"
  shift

  local output status level
  set +e
  if logging_enabled; then
    output="$(record_mic_level_sample "$sample_count" "$@" 2>>"$LOG_FILE" |
      ffmpeg \
        -hide_banner \
        -nostats \
        -f s16le \
        -ar 16000 \
        -ac 1 \
        -i pipe:0 \
        -af volumedetect \
        -f null - 2>&1)"
  else
    output="$(record_mic_level_sample "$sample_count" "$@" 2>/dev/null |
      ffmpeg \
        -hide_banner \
        -nostats \
        -f s16le \
        -ar 16000 \
        -ac 1 \
        -i pipe:0 \
        -af volumedetect \
        -f null - 2>&1)"
  fi
  status=$?
  set -e

  level="$(awk '/mean_volume:/ { level=$(NF-1) } END { print level }' <<<"$output")"
  if [ -n "$level" ]; then
    printf '%s\n' "$level"
    return 0
  fi

  logging_enabled && log "mic_level_monitor: sample produced no level; status=${status}"
  return 1
}

monitor_mic_level() {
  local expected_recording_pid="$1"
  local notification_id="$2"
  shift 2

  local monitor_shell_pid="$BASHPID"

  # shellcheck disable=SC2329 # Called indirectly by signal/exit traps below.
  cleanup_monitor() {
    trap - INT TERM EXIT
    pkill -TERM -P "$monitor_shell_pid" >/dev/null 2>&1 || true
    log "mic_level_monitor: cleanup complete; monitor_shell_pid=${monitor_shell_pid}"
  }

  trap 'cleanup_monitor; exit 0' INT TERM
  trap cleanup_monitor EXIT

  : >"$MIC_LEVEL_FILE"
  local sample_count level body status
  sample_count="$(mic_level_sample_count)"
  log "mic_level_monitor: starting sample loop; monitor_shell_pid=${monitor_shell_pid}; recording_pid=${expected_recording_pid}; notification_id=${notification_id}; source=${MIC_SOURCE}; sample_count=${sample_count}; sample_seconds=${LEVEL_SAMPLE_SECONDS}; update_seconds=${LEVEL_UPDATE_SECONDS}; no_signal_db=${NO_SIGNAL_DB}; quiet_db=${MIN_MEAN_VOLUME_DB}"

  while is_recording_session "$expected_recording_pid"; do
    level="$(capture_mic_level "$sample_count" "$@" || true)"
    if [ -n "$level" ]; then
      printf '%s\n' "$level" >"$MIC_LEVEL_FILE"
      body="$(mic_level_notification_body "$level")"
      status="$(sed -n '1p' <<<"$body")"
      update_recording_notification "$body" "$notification_id"
      log "mic_level_monitor: mean_dbfs=${level}; status=${status}"
    else
      update_recording_notification "Mic monitor waiting for level data..." "$notification_id"
    fi

    sleep "$LEVEL_UPDATE_SECONDS" || break
  done

  log "mic_level_monitor: sample loop ended"
}

start_mic_level_monitor() {
  mic_level_monitor_enabled || return 0
  command -v ffmpeg >/dev/null 2>&1 || return 0
  command -v pw-record >/dev/null 2>&1 || return 0
  command -v notify-send >/dev/null 2>&1 || return 0

  local expected_recording_pid notification_id
  expected_recording_pid="$(recording_pid || true)"
  notification_id="$(recording_notification_id)"
  [ -n "$expected_recording_pid" ] || return 0
  [ -n "$notification_id" ] || return 0

  stop_mic_level_monitor
  monitor_mic_level "$expected_recording_pid" "$notification_id" "$@" &
  printf '%s\n' "$!" >"$MIC_LEVEL_MONITOR_PID_FILE"
  rm -f "$LEGACY_MIC_LEVEL_MONITOR_PID_FILE"
  log "mic_level_monitor: pid=$!; recording_pid=${expected_recording_pid}; notification_id=${notification_id}"
}

stop_mic_level_monitor_pid_file() {
  local pid_file="$1"
  local pid
  pid="$(sed -n '1p' "$pid_file" 2>/dev/null || true)"
  rm -f "$pid_file"

  [ -n "${pid:-}" ] || return 0
  kill "$pid" >/dev/null 2>&1 || true
  wait "$pid" >/dev/null 2>&1 || true
  log "mic_level_monitor: stopped pid=${pid}"
}

stop_mic_level_monitor() {
  stop_mic_level_monitor_pid_file "$MIC_LEVEL_MONITOR_PID_FILE"
  stop_mic_level_monitor_pid_file "$LEGACY_MIC_LEVEL_MONITOR_PID_FILE"
}

die() {
  say "error: $*"
  notify_error "Error: $*"
  if [ "$CLEAN_ON_ERROR" = "1" ]; then
    cleanup_runtime_files
  fi
  exit 1
}

usage() {
  cat <<EOF
Usage:
  ./say_to_clip [--log] [--log-content] COMMAND
  ./say_to_clip start
  ./say_to_clip stop
  ./say_to_clip toggle
  ./say_to_clip status
  ./say_to_clip transcribe FILE
  ./say_to_clip help

Environment:
  DICTATE_MIC_SOURCE      ${MIC_SOURCE}
  DICTATE_PROVIDER        ${PROVIDER}
  DICTATE_TRANSCRIBE_PROVIDER ${TRANSCRIBE_PROVIDER}
  DICTATE_CLEAN_PROVIDER  ${CLEAN_PROVIDER}
  SAY_TO_CLIP_LIVE_LEVEL  ${LIVE_LEVEL_ENABLED}
  SAY_TO_CLIP_NO_SIGNAL_DB ${NO_SIGNAL_DB}
  SAY_TO_CLIP_LEVEL_UPDATE_SECONDS ${LEVEL_UPDATE_SECONDS}
  SAY_TO_CLIP_LEVEL_SAMPLE_SECONDS ${LEVEL_SAMPLE_SECONDS}
  DICTATE_WHISPER_MODEL   ${WHISPER_MODEL}
  DICTATE_WHISPER_LANGUAGE ${WHISPER_LANGUAGE}
  DICTATE_WHISPER_THREADS ${WHISPER_THREADS}
  DICTATE_OLLAMA_URL      ${OLLAMA_URL}
  DICTATE_OLLAMA_MODEL    ${OLLAMA_MODEL}
  DICTATE_OLLAMA_KEEP_ALIVE ${OLLAMA_KEEP_ALIVE}
  DICTATE_GROQ_BASE_URL   ${GROQ_BASE_URL}
  DICTATE_GROQ_TRANSCRIPTION_MODEL ${GROQ_TRANSCRIPTION_MODEL}
  DICTATE_GROQ_CHAT_MODEL ${GROQ_CHAT_MODEL}
  DICTATE_WORKDIR         ${WORKDIR}
  SAY_TO_CLIP_LOG         ${LOG_ENABLED}
  SAY_TO_CLIP_LOG_CONTENT ${LOG_CONTENT}
  SAY_TO_CLIP_MIN_MEAN_VOLUME_DB ${MIN_MEAN_VOLUME_DB}

Dependencies:
  pw-record, curl, jq, wl-copy
  whisper is required for local transcription
EOF
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "missing command: $1"
}

require_groq_key() {
  [ -n "$GROQ_API_KEY" ] || die "GROQ_API_KEY is required for Groq provider; put it in ~/.config/say_to_clip/env"
}

recording_pid() {
  if [ -f "$STATE_FILE" ]; then
    cat "$STATE_FILE"
  fi
}

is_recording() {
  local pid
  pid="$(recording_pid || true)"
  [ -n "${pid:-}" ] && kill -0 "$pid" >/dev/null 2>&1
}

is_recording_session() {
  local expected_pid="$1"
  local current_pid

  current_pid="$(recording_pid || true)"
  [ -n "$expected_pid" ] && [ "$current_pid" = "$expected_pid" ] && kill -0 "$expected_pid" >/dev/null 2>&1
}

start_recording() {
  require_command pw-record
  local target_args=()

  if is_recording; then
    die "already recording with pid $(recording_pid)"
  fi

  if [ -n "$MIC_SOURCE" ] && [ "$MIC_SOURCE" != "@DEFAULT_SOURCE@" ]; then
    target_args=(--target "$MIC_SOURCE")
  fi

  rm -f "$AUDIO_FILE" "$TRANSCRIPT_FILE" "$CLEANED_FILE"
  stop_mic_level_monitor
  dismiss_recording_notification
  log "--- dictation session start ---"
  log "config: mic=${MIC_SOURCE}; provider=${PROVIDER}; transcribe_provider=${TRANSCRIBE_PROVIDER}; clean_provider=${CLEAN_PROVIDER}; whisper_model=${WHISPER_MODEL}; whisper_language=${WHISPER_LANGUAGE}; whisper_threads=${WHISPER_THREADS}; ollama_url=${OLLAMA_URL}; ollama_model=${OLLAMA_MODEL}; ollama_keep_alive=${OLLAMA_KEEP_ALIVE}; groq_base_url=${GROQ_BASE_URL}; groq_transcription_model=${GROQ_TRANSCRIPTION_MODEL}; groq_chat_model=${GROQ_CHAT_MODEL}"
  say "Recording from ${MIC_SOURCE}. Run './say_to_clip stop' to finish."

  if logging_enabled; then
    pw-record \
      "${target_args[@]}" \
      --channels 1 \
      --rate 16000 \
      "$AUDIO_FILE" \
      >>"$LOG_FILE" 2>&1 &
  else
    pw-record \
      "${target_args[@]}" \
      --channels 1 \
      --rate 16000 \
      "$AUDIO_FILE" \
      >/dev/null 2>&1 &
  fi

  printf '%s\n' "$!" >"$STATE_FILE"
  show_recording_notification
  start_mic_level_monitor "${target_args[@]}"
}

stop_recording() {
  local pid
  local stop_start_ms
  pid="$(recording_pid || true)"
  [ -n "${pid:-}" ] || die "not recording"
  if ! kill -0 "$pid" >/dev/null 2>&1; then
    rm -f "$STATE_FILE"
    stop_mic_level_monitor
    dismiss_recording_notification
    die "recording process is no longer running; removed stale state"
  fi

  stop_start_ms="$(now_ms)"
  say "Stopping recording..."
  stop_mic_level_monitor
  dismiss_recording_notification
  kill -INT "$pid" >/dev/null 2>&1 || true
  for _ in $(seq 1 40); do
    kill -0 "$pid" >/dev/null 2>&1 || break
    sleep 0.1
  done
  kill -TERM "$pid" >/dev/null 2>&1 || true
  log "timing: stop_recording_ms=$(elapsed_ms "$stop_start_ms")"

  rm -f "$STATE_FILE"
  [ -s "$AUDIO_FILE" ] || die "recording did not create audio"
  CLEAN_ON_ERROR=1
  log "audio: file=${AUDIO_FILE}; bytes=$(wc -c <"$AUDIO_FILE")"
  if command -v ffprobe >/dev/null 2>&1; then
    log "audio_probe: $(ffprobe -v error -show_entries format=duration,size -of default=noprint_wrappers=1 "$AUDIO_FILE" | paste -sd ';' -)"
  fi
  check_audio_level "$AUDIO_FILE"
  transcribe_file "$AUDIO_FILE"
}

check_audio_level() {
  local audio_file="$1"
  local volume_output mean_volume

  command -v ffmpeg >/dev/null 2>&1 || return 0

  volume_output="$(ffmpeg -hide_banner -nostats -i "$audio_file" -af volumedetect -f null - 2>&1 || true)"
  mean_volume="$(awk '/mean_volume:/ { print $(NF-1) }' <<<"$volume_output" | tail -1)"
  [ -n "$mean_volume" ] || return 0

  log "audio_level: mean_volume_db=${mean_volume}; min_mean_volume_db=${MIN_MEAN_VOLUME_DB}"
  if awk -v mean="$mean_volume" -v min="$MIN_MEAN_VOLUME_DB" 'BEGIN { exit !(mean < min) }'; then
    logging_enabled || rm -f "$audio_file"
    die "recording looks too quiet (${mean_volume} dB); check the selected microphone source"
  fi
}

transcribe_file() {
  local audio_file="$1"
  local total_start_ms transcribe_start_ms clean_start_ms copy_start_ms
  require_command curl
  require_command jq
  require_command wl-copy

  total_start_ms="$(now_ms)"
  [ -f "$audio_file" ] || die "audio file not found: $audio_file"
  case "$audio_file" in
    "$WORKDIR"/*) CLEAN_ON_ERROR=1 ;;
  esac

  say "Transcribing with ${TRANSCRIBE_PROVIDER}..."
  notify "Transcribing"
  rm -f "$TRANSCRIPT_FILE" "$CLEANED_FILE"

  transcribe_start_ms="$(now_ms)"
  transcribe_audio "$audio_file"
  log "timing: transcription_ms=$(elapsed_ms "$transcribe_start_ms")"

  [ -s "$TRANSCRIPT_FILE" ] || die "transcription did not produce transcript text"

  local transcript
  transcript="$(sed 's/[[:space:]]\+$//' "$TRANSCRIPT_FILE")"
  [ -n "$transcript" ] || die "transcript was empty"
  log "transcript: provider=${TRANSCRIBE_PROVIDER}; chars=${#transcript}; lines=$(printf '%s\n' "$transcript" | wc -l)"
  log_content_block "transcript_text" "$transcript"

  say "Post-processing with ${CLEAN_PROVIDER}..."
  notify "Cleaning transcript"

  clean_start_ms="$(now_ms)"
  clean_transcript "$transcript"
  log "timing: cleanup_ms=$(elapsed_ms "$clean_start_ms")"

  local cleaned
  cleaned="$(sed 's/[[:space:]]\+$//' "$CLEANED_FILE")"
  [ -n "$cleaned" ] || die "cleanup returned an empty response"
  log "cleaned: provider=${CLEAN_PROVIDER}; chars=${#cleaned}; lines=$(printf '%s\n' "$cleaned" | wc -l)"
  log_content_block "cleaned_text" "$cleaned"

  copy_start_ms="$(now_ms)"
  copy_text "$cleaned"
  log "timing: clipboard_ms=$(elapsed_ms "$copy_start_ms")"
  log_content_block "copied_text" "$cleaned"
  say "Copied cleaned transcript to clipboard."
  log "timing: total_post_stop_ms=$(elapsed_ms "$total_start_ms")"
  log "--- dictation session end ---"
  cleanup_runtime_files
  CLEAN_ON_ERROR=0
  notify_ready
}

transcribe_audio() {
  local audio_file="$1"
  case "$TRANSCRIBE_PROVIDER" in
    local|whisper) transcribe_local "$audio_file" ;;
    groq) transcribe_groq "$audio_file" ;;
    *) die "unknown transcription provider: ${TRANSCRIBE_PROVIDER}" ;;
  esac
}

transcribe_local() {
  local audio_file="$1"
  require_command whisper

  say "Using local Whisper model '${WHISPER_MODEL}'..."
  log "transcription_request: provider=local; command=whisper; audio=${audio_file}; model=${WHISPER_MODEL}; language=${WHISPER_LANGUAGE}; threads=${WHISPER_THREADS}; output_dir=${WORKDIR}"
  if content_logging_enabled; then
    whisper "$audio_file" \
      --model "$WHISPER_MODEL" \
      --language "$WHISPER_LANGUAGE" \
      --fp16 False \
      --threads "$WHISPER_THREADS" \
      --output_format txt \
      --output_dir "$WORKDIR" \
      > >(tee -a "$LOG_FILE") \
      2> >(tee -a "$LOG_FILE" >&2)
  else
    whisper "$audio_file" \
      --model "$WHISPER_MODEL" \
      --language "$WHISPER_LANGUAGE" \
      --fp16 False \
      --threads "$WHISPER_THREADS" \
      --output_format txt \
      --output_dir "$WORKDIR" \
      >/dev/null 2>&1
  fi

  local produced_txt
  produced_txt="${audio_file%.*}.txt"
  if [ -f "$produced_txt" ] && [ "$produced_txt" != "$TRANSCRIPT_FILE" ]; then
    cp "$produced_txt" "$TRANSCRIPT_FILE"
    case "$produced_txt" in
      "${WORKDIR}"/*)
        logging_enabled || rm -f "$produced_txt"
        ;;
    esac
  fi
}

transcribe_groq() {
  local audio_file="$1"
  local response response_file curl_config http_code transcript

  require_groq_key
  say "Using Groq transcription model '${GROQ_TRANSCRIPTION_MODEL}'..."
  log "transcription_request: provider=groq; endpoint=${GROQ_TRANSCRIPTION_ENDPOINT}; audio=${audio_file}; bytes=$(wc -c <"$audio_file"); model=${GROQ_TRANSCRIPTION_MODEL}; language=${WHISPER_LANGUAGE}; response_format=json; api_key_present=yes"

  response_file="$(mktemp "${WORKDIR}/groq-transcription-response.XXXXXX.json")"
  curl_config="$(mktemp "${WORKDIR}/groq-curl.XXXXXX.conf")"
  printf 'header = "Authorization: Bearer %s"\n' "$GROQ_API_KEY" >"$curl_config"
  http_code="$(curl -sS -w '%{http_code}' -o "$response_file" --config "$curl_config" "$GROQ_TRANSCRIPTION_ENDPOINT" \
    -F "file=@${audio_file}" \
    -F "model=${GROQ_TRANSCRIPTION_MODEL}" \
    -F "response_format=json" \
    -F "language=${WHISPER_LANGUAGE}" || printf '000')"
  rm -f "$curl_config"
  response="$(cat "$response_file")"
  rm -f "$response_file"
  log_content_json_block "groq_transcription_response" "$response"
  log "groq_transcription_http_status: ${http_code}"
  [ "${http_code#2}" != "$http_code" ] || die "Groq transcription request failed with HTTP ${http_code}$(api_error_message "$response")"

  transcript="$(jq -r '.text // empty' <<<"$response" | sed 's/[[:space:]]\+$//')"
  [ -n "$transcript" ] || die "Groq transcription returned an empty response"
  printf '%s\n' "$transcript" >"$TRANSCRIPT_FILE"
}

clean_transcript() {
  local transcript="$1"
  case "$CLEAN_PROVIDER" in
    local|ollama) clean_ollama "$transcript" ;;
    groq) clean_groq "$transcript" ;;
    none|raw)
      log "cleanup_request: provider=none; action=copy transcript unchanged"
      printf '%s\n' "$transcript" >"$CLEANED_FILE"
      ;;
    *) die "unknown cleanup provider: ${CLEAN_PROVIDER}" ;;
  esac
}

clean_ollama() {
  local transcript="$1"
  local payload response response_file http_code cleaned

  say "Using local Ollama model '${OLLAMA_MODEL}'..."
  log "cleanup_request: provider=ollama; endpoint=${OLLAMA_URL}/api/chat; model=${OLLAMA_MODEL}; keep_alive=${OLLAMA_KEEP_ALIVE}; transcript_chars=${#transcript}; prompt_chars=${#PROMPT}"
  payload="$(jq -n \
    --arg model "$OLLAMA_MODEL" \
    --arg keep_alive "$OLLAMA_KEEP_ALIVE" \
    --arg content "${PROMPT}"$'\n\n'"Transcript:"$'\n'"${transcript}" \
    '{model: $model, messages: [{role: "user", content: $content}], stream: false, keep_alive: $keep_alive, options: {temperature: 0}}')"
  log_content_json_block "ollama_cleanup_payload" "$payload"

  response_file="$(mktemp "${WORKDIR}/ollama-cleanup-response.XXXXXX.json")"
  http_code="$(curl -sS -w '%{http_code}' -o "$response_file" "${OLLAMA_URL}/api/chat" \
    -H 'Content-Type: application/json' \
    -d "$payload" || printf '000')"
  response="$(cat "$response_file")"
  rm -f "$response_file"
  log_content_json_block "ollama_cleanup_response" "$response"
  log "ollama_cleanup_http_status: ${http_code}"
  [ "${http_code#2}" != "$http_code" ] || die "Ollama cleanup request failed with HTTP ${http_code}$(api_error_message "$response")"

  cleaned="$(jq -r '.message.content // empty' <<<"$response" | sed 's/[[:space:]]\+$//')"
  [ -n "$cleaned" ] || die "Ollama returned an empty response"
  printf '%s\n' "$cleaned" >"$CLEANED_FILE"
}

clean_groq() {
  local transcript="$1"
  local payload response response_file curl_config http_code cleaned

  require_groq_key
  say "Using Groq cleanup model '${GROQ_CHAT_MODEL}'..."
  log "cleanup_request: provider=groq; endpoint=${GROQ_CHAT_ENDPOINT}; model=${GROQ_CHAT_MODEL}; transcript_chars=${#transcript}; prompt_chars=${#PROMPT}; api_key_present=yes"
  payload="$(jq -n \
    --arg model "$GROQ_CHAT_MODEL" \
    --arg content "${PROMPT}"$'\n\n'"Transcript:"$'\n'"${transcript}" \
    '{model: $model, messages: [{role: "user", content: $content}], stream: false, temperature: 0}')"
  log_content_json_block "groq_cleanup_payload" "$payload"

  response_file="$(mktemp "${WORKDIR}/groq-cleanup-response.XXXXXX.json")"
  curl_config="$(mktemp "${WORKDIR}/groq-curl.XXXXXX.conf")"
  printf 'header = "Authorization: Bearer %s"\n' "$GROQ_API_KEY" >"$curl_config"
  http_code="$(curl -sS -w '%{http_code}' -o "$response_file" --config "$curl_config" "$GROQ_CHAT_ENDPOINT" \
    -H 'Content-Type: application/json' \
    -d "$payload" || printf '000')"
  rm -f "$curl_config"
  response="$(cat "$response_file")"
  rm -f "$response_file"
  log_content_json_block "groq_cleanup_response" "$response"
  log "groq_cleanup_http_status: ${http_code}"
  [ "${http_code#2}" != "$http_code" ] || die "Groq cleanup request failed with HTTP ${http_code}$(api_error_message "$response")"

  cleaned="$(jq -r '.choices[0].message.content // empty' <<<"$response" | sed 's/[[:space:]]\+$//')"
  [ -n "$cleaned" ] || die "Groq cleanup returned an empty response"
  printf '%s\n' "$cleaned" >"$CLEANED_FILE"
}

copy_text() {
  local text="$1"
  local old_pid

  old_pid="$(cat "$COPY_PID_FILE" 2>/dev/null || true)"
  log "clipboard_request: chars=${#text}; previous_pid=${old_pid:-none}"
  if [ -n "${old_pid:-}" ]; then
    kill "$old_pid" >/dev/null 2>&1 || true
  fi

  # Keep wl-copy alive so Wayland clipboard content persists without a manager.
  if logging_enabled; then
    printf '%s' "$text" | wl-copy --foreground >/dev/null 2>>"$LOG_FILE" &
  else
    printf '%s' "$text" | wl-copy --foreground >/dev/null 2>&1 &
  fi
  local copy_pid="$!"
  sleep 0.2
  kill -0 "$copy_pid" >/dev/null 2>&1 || die "wl-copy failed"
  printf '%s\n' "$copy_pid" >"$COPY_PID_FILE"
  log "clipboard_response: wl_copy_pid=${copy_pid}; status=running"
}

show_status() {
  if is_recording; then
    say "recording: yes (pid $(recording_pid))"
  else
    say "recording: no"
  fi
  say "audio: ${AUDIO_FILE}"
  say "transcript: ${TRANSCRIPT_FILE}"
  say "cleaned: ${CLEANED_FILE}"
  if logging_enabled; then
    say "log: ${LOG_FILE}"
  else
    say "log: disabled"
  fi
  if is_mic_level_monitor_running; then
    say "mic level monitor: yes (pid $(mic_level_monitor_pid))"
  else
    say "mic level monitor: no"
  fi
}

main() {
  while [ "$#" -gt 0 ]; do
    case "${1:-}" in
      --log)
        LOG_ENABLED=1
        shift
        ;;
      --log-content)
        LOG_ENABLED=1
        LOG_CONTENT=1
        shift
        ;;
      --)
        shift
        break
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      --*)
        usage
        die "unknown option: $1"
        ;;
      *)
        break
        ;;
    esac
  done

  local command="${1:-help}"
  if [ "$#" -gt 0 ]; then
    shift
  fi

  case "$command" in
    start) start_recording ;;
    stop) stop_recording ;;
    toggle)
      if is_recording; then
        stop_recording
      else
        start_recording
      fi
      ;;
    status) show_status ;;
    transcribe) transcribe_file "${1:?missing audio file}" ;;
    help|-h|--help) usage ;;
    *) usage; die "unknown command: $command" ;;
  esac
}

main "$@"
